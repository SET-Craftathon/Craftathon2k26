# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/craftathon

# API
API_URL=http://localhost:5000

# FastAPI NLP Service
FASTAPI_URL=http://localhost:8000

# Set to 'true' to use mock NLP responses (for local dev without FastAPI)
# Set to 'false' when running with the real FastAPI service
USE_MOCK_NLP=true
